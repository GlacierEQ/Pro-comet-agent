# comet-agent — environment variables
# Copy this to .env and fill in your values

# ── Server ─────────────────────────────────
PORT=8787
NODE_ENV=development

# ── Auth ───────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ── Database ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/comet_agent

# ── Redis ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Browser Engine ─────────────────────────
# Options: comet | playwright | stagehand
#   comet      — attaches to the running Comet browser via CDP (USE THIS for Comet agent)
#   playwright — spawns its own headless Chromium (fallback / CI)
#   stagehand  — NL-driven via Browserbase (requires OPENAI_API_KEY)
BROWSER_PROVIDER=comet

# Comet CDP endpoint — leave default unless Comet is on a non-standard port
COMET_CDP_URL=http://localhost:9222

# Headless mode — only applies when BROWSER_PROVIDER=playwright
BROWSER_HEADLESS=true

# ── Stagehand (only needed if BROWSER_PROVIDER=stagehand) ──
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── MyMap credentials ──────────────────────
MYMAP_EMAIL=your@email.com
MYMAP_PASSWORD=your_password_here
MYMAP_BASE_URL=https://www.mymap.ai

# ── Session management ─────────────────────
# How often to check for idle sessions (ms)
SESSION_CHECK_INTERVAL_MS=30000
# How long before an idle session is auto-evicted (ms) — default 15 min
SESSION_TIMEOUT_MS=900000

# ── Logging ────────────────────────────────
LOG_LEVEL=info
# Options: error | warn | info | debug
