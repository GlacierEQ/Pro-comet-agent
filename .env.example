# comet-agent — environment variables
# Copy this to .env and fill in your values

# ── Server ─────────────────────────────────
PORT=8787
NODE_ENV=development

# ── Auth ───────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ── Database ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/comet_agent

# ── Redis ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Browser Engine ─────────────────────────
# Options: playwright | stagehand
BROWSER_PROVIDER=playwright

# Headless mode (true for prod, false for local debugging)
BROWSER_HEADLESS=true

# ── Stagehand (only needed if BROWSER_PROVIDER=stagehand) ──
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── MyMap credentials ──────────────────────
MYMAP_EMAIL=your@email.com
MYMAP_PASSWORD=your_password_here
MYMAP_BASE_URL=https://www.mymap.ai

# ── Logging ────────────────────────────────
LOG_LEVEL=info
# Options: error | warn | info | debug
