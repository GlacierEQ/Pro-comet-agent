{
  "name": "comet-agent",
  "version": "2.0.0",
  "description": "Node/TypeScript browser automation server — Express API + Playwright engine + Stagehand adapter + MyMap workflow",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --testPathPattern=e2e",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "browsers:install": "npx playwright install chromium",
    "docker:build": "docker build -t comet-agent .",
    "docker:run": "docker run -p 8787:8787 comet-agent",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "axios": "^1.6.0",
    "node-fetch": "^3.3.2",
    "winston": "^3.11.0",
    "@prisma/client": "^5.6.0",
    "redis": "^4.6.10",
    "cheerio": "^1.0.0-rc.12",
    "playwright": "^1.44.0",
    "zod": "^3.22.4",
    "uuid": "^9.0.0",
    "rate-limiter-flexible": "^3.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.8",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.2.2",
    "tsx": "^4.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.16",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "prettier": "^3.0.3",
    "prisma": "^5.6.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "comet",
    "browser",
    "automation",
    "playwright",
    "stagehand",
    "agent",
    "typescript",
    "express",
    "mymap",
    "ai-agent"
  ],
  "author": "GlacierEQ",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GlacierEQ/comet-agent.git"
  },
  "bugs": {
    "url": "https://github.com/GlacierEQ/comet-agent/issues"
  },
  "homepage": "https://github.com/GlacierEQ/comet-agent#readme"
}
